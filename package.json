{
  "name": "noah",
  "version": "1.0.0",
  "description": "A desktop companion — a digital being who lives in your PC.",
  "private": true,
  "main": "dist/main/main/index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "tsc": "tsc",
    "build": "npm-run-all clean tsc:main build:renderer",
    "build:watch": "npm-run-all --parallel tsc:watch vite:watch",
    "tsc:main": "tsc -p tsconfig.main.json",
    "tsc:watch": "tsc -p tsconfig.main.json --watch",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "vite:watch": "vite build --config vite.renderer.config.ts --watch --emptyOutDir false",
    "start": "electron dist/main/main/index.js",
    "dev": "npm-run-all clean tsc:main build:renderer --parallel tsc:watch vite:watch start",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.3",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "canvas": "^3.2.3",
    "electron": "42.0.0-alpha.5",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.0.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.14"
  }
}
