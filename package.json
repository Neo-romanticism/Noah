{
  "name": "noah",
  "version": "1.0.0",
  "description": "A desktop companion — a digital being who lives in your PC.",
  "private": true,
  "main": "dist/main/index.cjs",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "tsc": "tsc",
    "build": "npm-run-all clean tsc:main tsc:renderer",
    "build:watch": "npm-run-all --parallel tsc:watch",
    "tsc:main": "tsc -p tsconfig.main.json",
    "tsc:renderer": "tsc -p tsconfig.renderer.json",
    "tsc:watch": "tsc --watch",
    "start": "electron dist/main/index.cjs",
    "dev": "npm-run-all --parallel build:watch start",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^30.0.0",
    "jest": "^29.0.0",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.0.0",
    "typescript": "^5.5.0"
  }
}
